#!/data/data/com.termux/files/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
AITermux GitHub 登录助手

Usage:
  aitermux-github-login
  aitermux-github-login --hidden
  aitermux-github-login --status
  aitermux-github-login --logout

说明：
  - 使用 GitHub 官方 CLI gh 保存凭据。
  - 默认明文输入 token，便于确认已输入；如需隐藏输入可加 --hidden。
  - Token 不会写入 shell history，不会写入 git remote，不会进入仓库。
  - 登录后会执行 gh auth setup-git，让 git push 自动使用 gh 凭据。
  - 推荐 classic token scopes：repo、read:org、gist。
EOF
}

ensure_gh() {
  if command -v gh >/dev/null 2>&1; then
    return 0
  fi
  if ! command -v pkg >/dev/null 2>&1; then
    echo "缺少 gh，且未找到 pkg，无法自动安装。" >&2
    return 1
  fi
  echo "未检测到 gh，正在安装 GitHub CLI..."
  pkg install -y gh
}

secure_gh_config_permissions() {
  chmod 700 "$HOME/.config" "$HOME/.config/gh" 2>/dev/null || true
  chmod 600 "$HOME/.config/gh/hosts.yml" 2>/dev/null || true
}

status() {
  ensure_gh
  gh auth status --hostname github.com
}

current_github_user() {
  awk '
    $1 == "github.com:" { in_host = 1; next }
    in_host && $1 == "user:" { print $2; exit }
    in_host && /^[^[:space:]]/ { in_host = 0 }
  ' "$HOME/.config/gh/hosts.yml" 2>/dev/null || true
}

clear_existing_login() {
  local user
  user="$(current_github_user)"
  if [ -n "$user" ]; then
    gh auth logout --hostname github.com --user "$user" >/dev/null 2>&1 || true
  fi
}

logout() {
  ensure_gh
  clear_existing_login
  git config --global --unset-all credential.https://github.com.helper 2>/dev/null || true
  git config --global --unset-all credential.helper 2>/dev/null || true
  echo "GitHub 登录信息已清理。"
}

login() {
  local input_mode="${1:-visible}"
  local token=""

  ensure_gh
  echo "请输入 GitHub token。"
  echo "建议 classic token scopes：repo、read:org、gist。"
  if [ "$input_mode" = "hidden" ]; then
    echo "当前为隐藏输入模式，输入不会显示在屏幕上。"
    printf 'GitHub token: '
    IFS= read -r -s token
    printf '\n'
  else
    echo "当前为明文输入模式，请确认周围环境安全。"
    printf 'GitHub token: '
    IFS= read -r token
  fi
  if [ -z "$token" ]; then
    echo "token 为空，已取消。" >&2
    return 1
  fi

  clear_existing_login
  printf '%s\n' "$token" | gh auth login --hostname github.com --with-token
  token=""
  gh auth setup-git --hostname github.com
  secure_gh_config_permissions
  if ! gh auth status --hostname github.com; then
    echo "GitHub 凭据验证失败。请检查 token 是否有效、scope 是否足够、是否已过期。" >&2
    return 1
  fi
  echo "GitHub 凭据已保存。以后 git push 会自动使用 gh。"
}

case "${1:-}" in
  -h|--help|help)
    usage
    ;;
  --status|status)
    status
    ;;
  --logout|logout)
    logout
    ;;
  --hidden|hidden)
    login hidden
    ;;
  "")
    login visible
    ;;
  *)
    echo "未知参数：$1" >&2
    usage >&2
    exit 2
    ;;
esac
